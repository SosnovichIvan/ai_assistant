# AI Assistant Configuration

# Server
AI_SERVER_HOST=0.0.0.0
AI_SERVER_PORT=8080
AI_SERVER_ENV=development

# Database (PostgreSQL with pgvector)
AI_DATABASE_URL=postgres://user:password@localhost:5432/ai_assistant?sslmode=disable
AI_DATABASE_POOL_SIZE=10

# OpenAI
AI_OPENAI_API_KEY=sk-your-openai-api-key
AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_OPENAI_EMBEDDING_DIMENSIONS=1536
AI_OPENAI_EMBEDDING_URL=https://api.openai.com/v1/embeddings

# Telegram Bot
AI_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
AI_TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
AI_TELEGRAM_WEBHOOK_PORT=8443

# JWT Authentication
AI_JWT_SECRET=your-super-secret-jwt-key-change-in-production
